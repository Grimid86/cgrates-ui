# ============================================
# UI-Bill Environment Configuration
# Copy to .env and adjust for your environment
# ============================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=uibill
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSLMODE=disable

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Apache Pulsar ---
PULsar_URL=pulsar://localhost:6650
PULSAR_ADMIN_URL=http://localhost:8080
PULSAR_TENANT=billing

# --- CGRateS ---
CGRATES_HOST=localhost
CGRATES_PORT=2012
CGRATES_PROTOCOL=jsonrpc

# --- JWT Secrets (rotate every 90 days) ---
JWT_SECRET_SELFCARE=change-me-sc-256-bit-secret
JWT_SECRET_OPERATOR=change-me-op-256-bit-secret
JWT_SECRET_ADMIN=change-me-ad-256-bit-secret
JWT_TTL_ACCESS=15m
JWT_TTL_REFRESH=7d

# --- Rate Limiting ---
RATE_LIMIT_SELFCARE_RPM=30
RATE_LIMIT_OPERATOR_RPS=100
RATE_LIMIT_ADMIN_RPS=50

# --- Security ---
CSRF_SECRET=change-me-csrf-secret
BCRYPT_COST=12
MFA_ISSUER=UI-Bill

# --- Branding / CDN ---
CDN_BASE_URL=http://localhost:9000/branding
MAX_LOGO_SIZE_MB=2

# --- Ports (local dev) ---
PORT_SELFCARE_GATEWAY=8081
PORT_OPERATOR_GATEWAY=8082
PORT_ADMIN_GATEWAY=8083

# SelfCare UI - Production Build
FROM node:20-alpine AS builder

WORKDIR /app
COPY frontend/selfcare-ui/package*.json ./
RUN npm ci

COPY frontend/selfcare-ui/ ./
RUN npm run build

# Production stage
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY infra/docker/nginx-selfcare.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
